root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
# Exempt Jetpack Compose composables from ktlint's function-naming rule —
# composables are PascalCase by Compose convention.
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview

[*.{yml,yaml,json,xml,md}]
indent_size = 2
