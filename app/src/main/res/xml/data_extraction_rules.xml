<?xml version="1.0" encoding="utf-8"?>
<!--
    Login feature — Data extraction rules (T014).

    Excludes Supabase auth storage and DataStore from cloud backup AND from
    device-to-device transfer. Auth tokens MUST stay on the device that
    obtained them (Constitution Principle IV).

    See: https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="supabase_session.xml" />
        <exclude domain="sharedpref" path="supabase_auth.xml" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="supabase_session.xml" />
        <exclude domain="sharedpref" path="supabase_auth.xml" />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
