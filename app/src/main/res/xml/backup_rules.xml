<?xml version="1.0" encoding="utf-8"?>
<!--
    Login feature — Auto-backup exclusion rules (T013).

    Excludes:
    - DataStore preference files that may hold any auth-derived state.
    - Supabase SDK's session storage. The SDK uses Android Keystore-backed
      EncryptedSharedPreferences under the hood; we still exclude the
      file-name pattern as a defense-in-depth.

    See: https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="sharedpref" path="supabase_session.xml" />
    <exclude domain="sharedpref" path="supabase_auth.xml" />
    <exclude domain="file" path="datastore/" />
</full-backup-content>
